# Server Configuration
# PORT is set automatically on Render/Railway/Fly; optional locally
PORT=5001
# Listen address (0.0.0.0 = all interfaces; required on most cloud hosts)
HOST=0.0.0.0
NODE_ENV=development

# Database (code accepts MONGO_URI or MONGODB_URI)
# Local:
MONGO_URI=mongodb://127.0.0.1:27017/buildquote-pro
# Live (MongoDB Atlas): create a free cluster, allow Network Access 0.0.0.0/0 (or your host IPs), then:
# MONGO_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/buildquote-pro

# JWT Secrets (CHANGE THESE IN PRODUCTION — never commit real secrets)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production

# JWT Expiration
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# CORS — browser origin of your static site (comma-separated for several URLs)
FRONTEND_URL=http://localhost:8000
# FRONTEND_URLS=https://app.netlify.app,https://www.yourdomain.com

# One-server live deploy: Node serves index.html + /js/... and API under /api
# Set true on Render/Railway when this repo root is next to /backend
# SERVE_FRONTEND=true
